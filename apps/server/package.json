{
  "name": "@hawkcode/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "echo 'no lint yet'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "setup": "tsx src/cli/setup.ts",
    "prisma": "prisma",
    "db:push:sqlite": "prisma db push --schema prisma/schema.sqlite.prisma",
    "db:generate:sqlite": "prisma generate --schema prisma/schema.sqlite.prisma"
  },
  "dependencies": {
    "@hawkcode/agent": "workspace:*",
    "@hawkcode/shared": "workspace:*",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^9.0.0",
    "@prisma/client": "^6.16.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "prompts": "^2.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^6.16.2",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
