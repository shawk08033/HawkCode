{
  "name": "hawkcode",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm -r dev",
    "dev:all": "pnpm -C apps/server dev & pnpm -C apps/worker dev & pnpm -C apps/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm -C apps/server prisma migrate dev",
    "db:generate": "pnpm -C apps/server prisma generate",
    "db:push:sqlite": "pnpm -C apps/server prisma db push --schema prisma/schema.sqlite.prisma",
    "db:generate:sqlite": "pnpm -C apps/server prisma generate --schema prisma/schema.sqlite.prisma",
    "setup": "pnpm -C apps/server setup"
  }
}
